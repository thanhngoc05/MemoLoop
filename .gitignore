# ==========================================================

# MemoLoop - Git ignore rules

# ==========================================================

# ----------------------------------------------------------

# 1. Node.js dependencies

# ----------------------------------------------------------

node_modules/

# ----------------------------------------------------------

# 2. Environment variables and secret configuration

# ----------------------------------------------------------

.env
.env.local
.env.development
.env.production
.env.test

# Allow environment template files

!.env.example

# ----------------------------------------------------------

# 3. Build outputs

# ----------------------------------------------------------

dist/
build/
out/

# ----------------------------------------------------------

# 4. Testing and coverage outputs

# ----------------------------------------------------------

coverage/
test-results/
playwright-report/
blob-report/

# ----------------------------------------------------------

# 5. Log files

# ----------------------------------------------------------

*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------

# 6. Runtime and process files

# ----------------------------------------------------------

*.pid
*.pid.lock
pids/

# ----------------------------------------------------------

# 7. Cache and temporary files

# ----------------------------------------------------------

.cache/
.temp/
tmp/
temp/
*.tmp
*.temp

# ----------------------------------------------------------

# 8. Editor and IDE settings

# ----------------------------------------------------------

.vscode/
.idea/
*.code-workspace

# ----------------------------------------------------------

# 9. Operating system generated files

# ----------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------

# 10. Prisma and local database files

# ----------------------------------------------------------

*.db
*.db-journal

# ----------------------------------------------------------

# 11. Local uploads and generated files

# ----------------------------------------------------------

uploads/
generated/

# ----------------------------------------------------------

# 12. Local certificate and key files

# ----------------------------------------------------------

*.pem
*.key
*.crt

# ----------------------------------------------------------

# 13. Package manager cache

# ----------------------------------------------------------

.npm/
.yarn/
.pnpm-store/

# ----------------------------------------------------------

# 14. Docker local override files

# ----------------------------------------------------------

docker-compose.override.yml
compose.override.yml
